# Convection Treshold
SST.Tres <- SST %>%
crop(.,extent(c(0,360,-5,5))) %>% cellStats(., stat="mean",na.rm=T)
Coord.E <- SST[[1]] %>% crop(.,extent(c(0,360,-5,5))) %>%
rasterToPoints(.) %>% .[,-3]
# SST values above
SST.c <- crop(SST,extent(c(0,360,-5,5))) %>%
rasterToPoints(.) %>% .[,-c(1,2)]
cells.above <- SST.c >= SST.Tres
# ELI calculation
Coord.E[ cells.above ,1]
View(Coord.E)
Coord.E <- SST %>% crop(.,extent(c(0,360,-5,5))) %>%
rasterToPoints(.) %>% .[,-3]
# ELI calculation
Coord.E[ cells.above ,1] %>% .[. >=115 & . <=360-70]
# ELI calculation
ELI <- Coord.E[ cells.above ,1] %>%
.[. >=115 & . <=360-70] %>%
mean()
write.csv(ELI, "Current_ELI.csv")
